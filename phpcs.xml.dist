<?xml version="1.0"?>
<ruleset name="pagemaker/php">
    <arg name="warning-severity" value="8" />
    <arg name="extensions" value="php" />

    <rule ref="PSR12">
        <properties>
            <property name="testVersion" value="7.3" />
        </properties>
    </rule>

    <file>app/</file>
</ruleset>
